// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Lead {
  id                String   @id @default(uuid())
  nome              String?
  email             String?
  whatsapp          String?
  empresa           String?
  setor             String?
  tamanho_equipe    String?
  desafio_principal String?
  usa_plataforma    String?
  score             Int      @default(0)
  classificacao     String   @default("INCOMPLETO") // QUALIFICADO, DESCARTADO, INCOMPLETO
  status            String   @default("EM_ANDAMENTO") // EM_ANDAMENTO, FINALIZADO
  resumo_conversa   String?
  pitch             String?
  historico_chat    String // JSON stringified
  criado_em         DateTime @default(now())
  atualizado_em     DateTime @updatedAt

  @@index([classificacao])
  @@index([score])
  @@index([criado_em])
}
